# ShadowCursor Environment Variables

# Pro mode — SmartQuiz proxy URL (backend adds the real API key)
SMARTQUIZ_PROXY_URL=https://api.smartquiz.cloud/v1/shadow-cursor

# BYOK mode — user provides these in extension settings, not here
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPGRAM_API_KEY=...
